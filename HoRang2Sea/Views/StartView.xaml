            <dxlc:TileLayoutControl x:Name="layoutItems" Background="{x:Null}"  ItemSpace="10" LayerSpace="80"
                                Grid.Row="1" Grid.RowSpan="2" Grid.Column="2" Orientation="Horizontal" AnimateScrolling="False" Visibility="Visible">
                <dxlc:TileLayoutControl.Resources>
                    <Style TargetType="dxlc:Tile">
                        <Style.Triggers>
                            <Trigger Property="Size" Value="ExtraLarge">
                                <Setter Property="Width" Value="500"/>
                                <Setter Property="Height" Value="470"/>
                            </Trigger>
                            <Trigger Property="Size" Value="Large">
                                <Setter Property="Width" Value="490"/>
                                <Setter Property="Height" Value="310"/>
                            </Trigger>
                            <Trigger Property="Size" Value="ExtraSmall">
                                <Setter Property="Width" Value="240"/>
                                <Setter Property="Height" Value="230"/>
                            </Trigger>
                        </Style.Triggers>
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="MaximizedContentTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" Margin="16">
                                        <TextBlock Text="{Binding}" FontFamily="Segoe UI Light" FontSize="48" />
                                        <TextBlock FontSize="14" TextWrapping="Wrap">
                                        You can define an alternative content template when Tile is maximized using the MaximizedContentTemplate property.
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>
                    <SolidColorBrush x:Key="color2" Color="#FFDA8515" />
                    <SolidColorBrush x:Key="color3" Color="#FF54AF0E" />
                </dxlc:TileLayoutControl.Resources>


                <!--
                <dxlc:Tile Size="ExtraSmall" Background="DarkSlateBlue" >
                    <Grid>
                        <dx:DXImage gif:ImageBehavior.AnimatedSource="/Resource/Fuelcell.png"  Margin="2" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Label Content="Fuel cell components" Foreground="DarkSlateBlue"  HorizontalAlignment="Right" FontSize="15" Margin="10 0"/>
                    </Grid>
                </dxlc:Tile>
                 -->

                <dxlc:Tile Size="Large"  Grid.Column="1" Grid.RowSpan="2" Background="Transparent" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Left"
                       ContentChangeInterval="00:00:03" AnimateContentChange="True" dxlc:FlowLayoutControl.IsFlowBreak="True" Click="Tile_Click_1" Margin="0,0,0,0">

                    <dxlc:TileLayoutControl.GroupHeader>
                        <Label Foreground="Black" HorizontalAlignment="Right">News</Label>
                    </dxlc:TileLayoutControl.GroupHeader>
                    <dxlc:Tile.ContentSource>
                        <dx:FrameworkElements>
                            <dx:DXImage Margin="2" Source="/Resource/Renault-Scenic-Vision-Concept-car-28.png" Stretch="UniformToFill" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <dx:DXImage Margin="2" Source="/Resource/Renault-Scenic-Vision-Concept-car-29.png" Stretch="UniformToFill" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </dx:FrameworkElements>
                    </dxlc:Tile.ContentSource>
                </dxlc:Tile>




                <dxlc:Tile  Header="" Size="Small" Background="#995577ff" FontSize="15" dxlc:FlowLayoutControl.IsFlowBreak="True">
                    <dxlc:TileLayoutControl.GroupHeader>
                        <Label Foreground="Black">Tutorials</Label>
                    </dxlc:TileLayoutControl.GroupHeader>
                    <Grid>
                        <Label Content="Tutorial1 FishingBoat" Foreground="White"/>
                        <dx:DXImage Source="/Resource/Vehiclesflat/56-FishingBoat.svg" Width="40" Margin="0 -60 0 0"/>
                        
                    </Grid>
                </dxlc:Tile>

                <dxlc:Tile Content="Tutorial2" Header="" Size="Small" Background="#665577ff" FontSize="15"/>
                <dxlc:Tile Content="Tutorial3" Header="" Size="Small" Background="#665577ff" FontSize="15"/>
                <dxlc:Tile Content="Tutorial4" Header="" Size="Small" Background="#66ddddff" FontSize="15"/>

                <!--
                <dxlc:Tile Content="Tutorial5" Header="" Size="Small" Background="#ffaaaaff" FontSize="15"/>
                <dxlc:Tile Content="Tutorial6" Header="" Size="Small" Background="#66ddddff" FontSize="15"/>
                -->


            </dxlc:TileLayoutControl>



        </Grid>
