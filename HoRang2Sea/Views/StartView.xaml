<UserControl x:Class="HoRang2Sea.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:HoRang2Sea.Views"
             xmlns:gif="http://wpfanimatedgif.codeplex.com"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxr="http://schemas.devexpress.com/winfx/2008/xaml/ribbon"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <DockPanel>
        <!-- Top Ribbon -->
        <dxr:RibbonControl DockPanel.Dock="Top" x:Name="paintRibbon"
                           AllowCustomization="False" Visibility="Visible"
                           ShowApplicationButton="False" RibbonHeaderVisibility="Collapsed"
                           PageCategoryAlignment="Default" RibbonTitleBarVisibility="Visible"
                           RibbonStyle="Office2019" ToolbarShowMode="Default" IsSimplified="True">
            <dxr:RibbonPage Caption="Start">
                <dxr:RibbonPageGroup Caption="Links">
                    <dxb:BarButtonItem Content="About" Glyph="{dx:DXImage 'SvgImages/Outlook Inspired/About.svg'}" RibbonStyle="SmallWithText" />
                    <dxb:BarButtonItem Content="HoRang2 Page" Glyph="{dx:DXImage 'SvgImages/Icon Builder/Actions_Home.svg'}" RibbonStyle="SmallWithText" ItemClick="BarButtonItem_Click_Horang2"/>
                    <dxb:BarButtonItem Content="Profile Download" Glyph="{dx:DXImage 'SvgImages/Icon Builder/Actions_Home.svg'}" RibbonStyle="SmallWithText" ItemClick="BarButtonItem_Click_Profile"/>
                    <dxb:BarButtonItem Content="Manual" Glyph="{dx:DXImage 'SvgImages/RichEdit/DocumentStatistics.svg'}" RibbonStyle="SmallWithText" />
                    <dxb:BarButtonItem Content="HELP" Glyph="{dx:DXImage 'SvgImages/DiagramIcons/BindingEditorHelpIcon.svg'}" RibbonStyle="SmallWithText" />
                    <dxb:BarButtonItem Content="Contact us" Glyph="{dx:DXImage 'SvgImages/Business Objects/BO_Contact.svg'}" RibbonStyle="SmallWithText" />
                </dxr:RibbonPageGroup>
            </dxr:RibbonPage>
        </dxr:RibbonControl>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT SIDEBAR (original style) ===== -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Image Source="/Resource/startpage.png" Grid.RowSpan="3" HorizontalAlignment="Stretch" VerticalAlignment="Top" Stretch="None"/>
                <Image Source="/Resource/path153647-3.png" Margin="25,80,25,0" Width="120" Stretch="Uniform" VerticalAlignment="Top"/>

                <StackPanel Grid.Row="2" VerticalAlignment="Bottom" Margin="0,0,0,40">
                    <Image Source="{iconPacks:CodiconsImage Kind=Account,Brush=White}" Opacity="0.7" HorizontalAlignment="Center" Width="22"/>
                    <Label Content="Account" HorizontalAlignment="Center" Foreground="LightGray" FontSize="12"/>
                    <Label Content="Login | New ID" HorizontalAlignment="Center" Foreground="Gray" FontSize="11"/>
                </StackPanel>
            </Grid>

            <!-- ===== RIGHT: Video (top) + Content (bottom) ===== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Video - Uniform (no crop) with dark background -->
                <Border Grid.Row="0" Background="#E8E8EE">
                    <MediaElement Name="myMediaElement" Volume="0" LoadedBehavior="Play"
                                  Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <MediaElement.Triggers>
                            <EventTrigger RoutedEvent="MediaElement.Loaded">
                                <EventTrigger.Actions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <MediaTimeline Source="StartMovie.mp4" Storyboard.TargetName="myMediaElement" RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger.Actions>
                            </EventTrigger>
                        </MediaElement.Triggers>
                    </MediaElement>
                </Border>

                <!-- Bottom content area -->
                <Border Grid.Row="1" Background="#DDDDE5" Padding="20,14,20,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Fuel Cell card -->
                        <Border Grid.Column="0" Width="120" CornerRadius="8" Background="#483D8B" Margin="0,0,16,0" ClipToBounds="True" Cursor="Hand"
                                MouseLeftButtonUp="FuelCell_Click">
                            <Grid>
                                <dx:DXImage gif:ImageBehavior.AnimatedSource="/Resource/Fuelcell.png" Margin="8" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="Fuel Cell" Foreground="White" FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            </Grid>
                        </Border>

                        <!-- Tutorials -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Tutorials" FontSize="14" FontWeight="SemiBold" Foreground="#444444" Margin="0,0,0,8"/>
                            <WrapPanel>
                                <Border Width="110" Height="58" CornerRadius="5" Background="#5566AA" Margin="0,0,6,6" Cursor="Hand"
                                        Tag="Fishing Boat" MouseLeftButtonUp="Tutorial_Click">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <dx:DXImage Source="/Resource/Vehiclesflat/56-FishingBoat.svg" Width="24" Height="24"/>
                                        <TextBlock Text="Fishing Boat" Foreground="#FFFFFF" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Width="110" Height="58" CornerRadius="5" Background="#5566AA" Margin="0,0,6,6" Cursor="Hand"
                                        Tag="Port Guide Ship" MouseLeftButtonUp="Tutorial_Click">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <dx:DXImage Source="/Resource/Vehiclesflat/57-PortGuideShip.svg" Width="24" Height="24"/>
                                        <TextBlock Text="Port Guide Ship" Foreground="#FFFFFF" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Width="110" Height="58" CornerRadius="5" Background="#5566AA" Margin="0,0,6,6" Cursor="Hand"
                                        Tag="Training Ship" MouseLeftButtonUp="Tutorial_Click">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <dx:DXImage Source="/Resource/Vehiclesflat/55-TrainingShip.svg" Width="24" Height="24"/>
                                        <TextBlock Text="Training Ship" Foreground="#FFFFFF" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                </WrapPanel>
                        </StackPanel>

                        <!-- News + links -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Width="180" Margin="16,0,0,0">
                            <TextBlock Text="News" FontSize="14" FontWeight="SemiBold" Foreground="#444444" Margin="0,0,0,6"/>
                            <Border Height="80" CornerRadius="6" ClipToBounds="True" Margin="0,0,0,10">
                                <dx:DXImage Source="/Resource/Renault-Scenic-Vision-Concept-car-28.png" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="HELP" Foreground="#777" FontSize="11" Margin="0,0,6,0"/>
                                <TextBlock Text="|" Foreground="#AAA" FontSize="11" Margin="0,0,6,0"/>
                                <TextBlock Text="Contact us" Foreground="#777" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
