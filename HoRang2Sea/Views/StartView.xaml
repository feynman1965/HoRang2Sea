    <DockPanel>
        <dxr:RibbonControl DockPanel.Dock="Top" x:Name="paintRibbon"
                                   AllowCustomization="False"
                                   Visibility="Visible"
                                   Grid.Row="0"
                                   ShowApplicationButton="False"
                                   RibbonHeaderVisibility="Collapsed"
                           PageCategoryAlignment="Default"
                           RibbonTitleBarVisibility="Visible"
                           RibbonStyle="Office2019"
                           ToolbarShowMode="Default"
                           IsSimplified="True">

            <dxr:RibbonControl.ToolbarItems>
                <dxr:RibbonSpacingSelectorItemLink BarItemName="spacingSelector" />
            </dxr:RibbonControl.ToolbarItems>

            <dxr:RibbonPage Caption="Start">
                <dxr:RibbonPageGroup Caption="Tutorials">

                    <dxb:BarButtonItem 
                                       Content="About"
                                       Glyph="{dx:DXImage 'SvgImages/Outlook Inspired/About.svg'}"
                                       RibbonStyle="SmallWithText" />
                    <dxb:BarButtonItem 
                           Content="HoRang2 Page"
                           Glyph="{dx:DXImage 'SvgImages/Icon Builder/Actions_Home.svg'}"
                           RibbonStyle="SmallWithText"
                           ItemClick="BarButtonItem_Click_Horang2"/>
                    <dxb:BarButtonItem 
                           Content="Profile Download Page"
                           Glyph="{dx:DXImage 'SvgImages/Icon Builder/Actions_Home.svg'}"
                           RibbonStyle="SmallWithText" 
                           ItemClick="BarButtonItem_Click_Profile"/>
                    <dxb:BarButtonItem 
                                       Content="Manual"
                                       Glyph="{dx:DXImage 'SvgImages/RichEdit/DocumentStatistics.svg'}"
                                       RibbonStyle="SmallWithText" />
                    <dxb:BarButtonItem 
                                       Content="HELP"
                                       Glyph="{dx:DXImage 'SvgImages/DiagramIcons/BindingEditorHelpIcon.svg'}"
                                       RibbonStyle="SmallWithText" />
                    <dxb:BarButtonItem 
                                       Content="Contact us"
                                       Glyph="{dx:DXImage 'SvgImages/Business Objects/BO_Contact.svg'}"
                                       RibbonStyle="SmallWithText" />
                </dxr:RibbonPageGroup>
            </dxr:RibbonPage>
        </dxr:RibbonControl>
        <Grid >





            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="0.7*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <MediaElement Name="myMediaElement" Volume="0" Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" Grid.ColumnSpan="2" LoadedBehavior="Play" Visibility="Visible" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" >
                <MediaElement.Triggers>
                    <EventTrigger RoutedEvent="MediaElement.Loaded">
                        <EventTrigger.Actions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <MediaTimeline Source="StartMovie.mp4" Storyboard.TargetName="myMediaElement" RepeatBehavior="Forever" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger.Actions>
                    </EventTrigger>
                </MediaElement.Triggers>
            </MediaElement>
            <Image Source="/Resource/startpage.png" Grid.RowSpan="3"  HorizontalAlignment="Stretch" VerticalAlignment="Top"   Stretch="None" />
            <Image Grid.ColumnSpan="3" Source="/Resource/path153647-3.png" Margin="60 100 0 0" HorizontalAlignment="Left" VerticalAlignment="top" Width="150" MinHeight="100" Stretch="Uniform"/>

            <StackPanel Grid.RowSpan="3" VerticalAlignment="Bottom" Margin="0 0 0 150">
                <Image Source="{iconPacks:CodiconsImage Kind=Account,Brush=White}" Opacity="0.7"  HorizontalAlignment="Center" VerticalAlignment="top"  Width="25">
                    <!--<Image.Style>
                    <Style TargetType="Image">
                        <Setter Property="Width" Value="20"/>
                        <Setter Property="Height" Value="20"/>
                    </Style>
                </Image.Style>-->
                </Image>
                <Label Content="Account" HorizontalAlignment="Center" Foreground="LightGray" FontSize="14"/>
                <Label Content="  Login  |  New ID" HorizontalAlignment="Center" Foreground="LightGray" FontSize="12"/>
            </StackPanel>

