<UserControl 
    x:Class="HoRang2Sea.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm" 
    xmlns:ViewModels="clr-namespace:HoRang2Sea.ViewModels"
    xmlns:local="clr-namespace:HoRang2Sea.Views" 
    xmlns:services="clr-namespace:HoRang2Sea.Services" 
    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars" 
    xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking" 
    xmlns:p1="clr-namespace:HoRang2Sea.Services"
    xmlns:dxr="http://schemas.devexpress.com/winfx/2008/xaml/ribbon" 
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid" 
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    mc:Ignorable="d" d:DesignHeight="300" d:DesignWidth="300" x:Name="myCustomControl"
    Loaded="myCustomControl_Loaded">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/HoRang2Sea;component/Resources.xaml" />
            </ResourceDictionary.MergedDictionaries>
          
            <Style x:Key="myGlyphStyle" TargetType="Image">
                <Setter Property="Height" Value="20"/>
                <Setter Property="Width" Value="20"/>
            </Style>
            <Style x:Key="myGlyphStyle30" TargetType="Image">
                <Setter Property="Height" Value="30"/>
                <Setter Property="Width" Value="30"/>
            </Style>

            <ControlTemplate x:Key="HomeControlPaneTemplate" TargetType="{x:Type ContentControl}">
                <Grid Margin="40,0,40,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource PageHeaderStyle}" Text="Home" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button   Style="{StaticResource BackstageContentButtonStyle}" Padding="54,17,54,8" Command="{Binding CreateBlankDocumentCommand}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>

                            </Grid.RowDefinitions>
                            <!--<Border Background="White" BorderThickness="1" BorderBrush="LightGray" Width="70" Height="90" />-->
                                <dx:DXImage Source="{iconPacks:FontAwesomeImage Kind=SaveSolid,Brush=PowderBlue}" Width="35" />
                                <dx:DXImage Source="{iconPacks:FontAwesomeImage Kind=SaveRegular,Brush=Gray}" Width="35"/>
                            <TextBlock Grid.Row="1" Text="Save" FontWeight="Bold" Margin="0,8" HorizontalAlignment="Center" />
                        </Grid>
                    </Button>
                    <Button  Style="{StaticResource BackstageContentButtonStyle}" Padding="54,17,54,8" Command="{Binding CreateBlankDocumentCommand}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>

                            </Grid.RowDefinitions>
                                <!--<Border Background="White" BorderThickness="1" BorderBrush="LightGray" Width="70" Height="90" />-->
                            <dx:DXImage Source="{iconPacks:EvaIconsImage Kind=File,Brush=PowderBlue}" Width="25" Margin="-10 0 0 0"/>
                            <dx:DXImage Source="{iconPacks:FontistoImage Kind=Import,Brush=Gray}" Width="35"/>
                            <TextBlock Grid.Row="1" Text="Load" FontWeight="Bold" Margin="0,8" HorizontalAlignment="Center" />
                        </Grid>
                    </Button>
                    </StackPanel>
                    <Separator Grid.Row="2" Margin="0,10" />
                    <ContentControl Grid.Row="3" Content="Recent Documents" SnapsToDevicePixels="True" Focusable="False" IsTabStop="False" FocusVisualStyle="{x:Null}" Margin="0,10,0,16" FontSize="16" FontWeight="SemiBold"/>
                    <dxg:GridControl Grid.Row="4" ItemsSource="{Binding RecentDocuments}" ShowBorder="False" Style="{StaticResource TransparentGridStyle}">
                        <dxg:GridControl.Columns>
                            <dxg:GridColumn FieldName="Image" Width="60" ImageAlignment="Center" UnboundType="Object" ReadOnly="True" AllowResizing="False" Image="{dx:DXImage SvgImages/Outlook Inspired/New.svg}" >
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <dx:DXImage Source="{dx:DXImage SvgImages/Export/ExportToRTF.svg}" Stretch="None" />
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="Name" Width="3*" UnboundType="string" UnboundExpression="[Caption] + ';' + [Description]" AllowResizing="False">
                                <dxg:GridColumn.CellDisplayTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0">
                                            <TextBlock Text="{Binding RowData.Row.Caption}" Margin="0,2,0,0" FontSize="18"/>
                                            <TextBlock Text="{Binding RowData.Row.Description}" Margin="0,2"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </dxg:GridColumn.CellDisplayTemplate>
                            </dxg:GridColumn>
                            <dxg:GridColumn FieldName="DateModified" Width="*" Header="Date modified">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Value}" FontSize="12" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControl.Columns>
                    </dxg:GridControl>
                </Grid>
            </ControlTemplate>
            
            
            <ControlTemplate x:Key="NewControlPaneTemplate" TargetType="{x:Type ContentControl}">
                <Grid Margin="40,0,40,0">
                    <Grid.Background>
                        <ImageBrush ImageSource="pack://application:,,,/HoRang2Sea;component/Resource/MainImage.png" Stretch="Uniform"/>
                    </Grid.Background>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="250"/>
                    </Grid.RowDefinitions>
                    
                    
                    <TextBlock Style="{StaticResource PageHeaderStyle}" Text="New" />
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding ProjectViewModels}" Margin="0 30 0 0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Left" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type ViewModels:ProjectViewModel}">
                                <Button Style="{StaticResource BackstageContentButtonStyle}" Padding="30,15,30,15" Margin="5" Command="{Binding ElementName=myCustomControl, Path=DataContext.CreatDocumentCommand}"
                                        CommandParameter="{Binding Name}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border  x:Name ="MyBorder"  BorderThickness="1" BorderBrush="LightGray" Width="150" Height="160">
                                                <Border.Background>
                                                    <SolidColorBrush x:Name="myAnimatedBrush" Color="White" />
                                                </Border.Background>
                                                <Grid>
                                                    <dx:DXImage x:Name="MyImage" Source="{Binding Image}" RenderSize="20,20" Margin="25 50" dxb:ImageColorizer.Color="Gray"/>
                                                    <Label Content="{Binding Name}"  Margin="0,8,0,0" HorizontalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <EventTrigger RoutedEvent="Mouse.MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ThicknessAnimation  Storyboard.TargetName="MyImage"  Storyboard.TargetProperty="Margin" Duration="0:0:0.4" FillBehavior="Stop" From="1 50 49 50" To="25 50" />
                                                            <ColorAnimation Storyboard.TargetName="myAnimatedBrush" Storyboard.TargetProperty="Color" To="AliceBlue"  Duration="0:0:0.4" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="Mouse.MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ColorAnimation Storyboard.TargetName="myAnimatedBrush" Storyboard.TargetProperty="Color" To="White"  Duration="0:0:0.2" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>


                </Grid>
            </ControlTemplate>
            
            
            <ControlTemplate x:Key="InfoControlPaneTemplate" TargetType="{x:Type ContentControl}">
                <StackPanel Margin="40,0,0,0">
                    <TextBlock Style="{StaticResource PageHeaderStyle}" Text="About" />
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="200"/>
                        </Grid.RowDefinitions>
                        <MediaElement Grid.Row="0" Name="myMediaElement" Source="InfoMovie.mp4" LoadedBehavior="Play"  Margin="10,10,50,50" Visibility="Visible" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" >
                        </MediaElement>
                        <!--
                            <MediaElement.Triggers>
                                <EventTrigger RoutedEvent="MediaElement.Loaded">
                                    <EventTrigger.Actions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <MediaTimeline Source="InfoMovie.mp4" Storyboard.TargetName="myMediaElement" RepeatBehavior="Forever"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger.Actions>
                                </EventTrigger>
                            </MediaElement.Triggers>
                            -->
                       
                    </Grid>
                </StackPanel>
            </ControlTemplate>
        </ResourceDictionary>
    </UserControl.Resources>
    
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>
        <dxr:RibbonControl x:Name="RibbonControl" 
                           ShowApplicationButton ="True"
                           ApplicationButtonText ="Home"
                           ApplicationButtonLargeIcon="/HoRang2Sea;component/Resource/tigerh2icon.svg"
                           PageCategoryAlignment="Right"
                           RibbonTitleBarVisibility="Visible"
                           RibbonStyle="Office2019"
                           ToolbarShowMode="Default"
                           IsSimplified="True"
                           
                           >
            <dxmvvm:Interaction.Behaviors>
                <services:BackstageViewService/>
                <dxmvvm:EventToCommand EventName="BackstageOpened" Command="{Binding BackstageOpenedCommand}" />
            </dxmvvm:Interaction.Behaviors>
            <dxr:RibbonControl.ApplicationMenu>
                <dxr:BackstageViewControl CloseButtonVisibility="Collapsed" >
                    <dxr:BackstageViewControl.TabPaneStyle>
                        <Style TargetType="dxr:BackstageViewLeftPartContentControl">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                            <Grid>
                                            <Border CornerRadius="20">
                                                <Image Source="/Resource/startpage.png" Grid.RowSpan="2"  HorizontalAlignment="Stretch" VerticalAlignment="Top"   Stretch="None" Width="250" />
                                            </Border>

                                            <ContentControl Content="{Binding}" />
                                            </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </dxr:BackstageViewControl.TabPaneStyle>
                    <dxr:BackstageButtonItem Margin="0 30" 
                                             Glyph="{iconPacks:FontAwesomeImage Kind=ArrowAltCircleLeftRegular, Brush=White}" GlyphStyle="{StaticResource myGlyphStyle30}" Placement="Top"/>
                    
                    <dxr:BackstageTabItem Content="Home"  Margin="0 5"
                                          Glyph="{iconPacks:JamIconsImage Kind=Home ,Brush=White}" GlyphStyle="{StaticResource myGlyphStyle}">
                        <dxr:BackstageTabItem.ControlPane>
                            <ContentControl Template="{StaticResource HomeControlPaneTemplate}" SnapsToDevicePixels="True" Focusable="False" FocusVisualStyle="{x:Null}" IsTabStop="False" />
                        </dxr:BackstageTabItem.ControlPane>
                    </dxr:BackstageTabItem>
                    
                    <dxr:BackstageTabItem Content="New"  Margin="0 5"
                                          Glyph="{iconPacks:ForkAwesomeImage Kind=FileOutline, Brush=White}" GlyphStyle="{StaticResource myGlyphStyle}" >
                        <dxr:BackstageTabItem.ControlPane>
                            <ContentControl Template="{StaticResource NewControlPaneTemplate}" SnapsToDevicePixels="True" Focusable="False" FocusVisualStyle="{x:Null}" IsTabStop="False" />
                        </dxr:BackstageTabItem.ControlPane>
                    </dxr:BackstageTabItem>
                    <dxr:BackstageSeparatorItem />
                    
                    <dxr:BackstageTabItem Content="About" FontSize="15" Margin="0 5">
                        <dxr:BackstageTabItem.ControlPane>
                            <ContentControl Template="{StaticResource InfoControlPaneTemplate}" Focusable="False" FocusVisualStyle="{x:Null}" IsTabStop="False"/>
                        </dxr:BackstageTabItem.ControlPane>
                    </dxr:BackstageTabItem>
                    <dxr:BackstageSeparatorItem Placement="Bottom"/>
                    <dxr:BackstageButtonItem Content="Close"  Placement="Bottom"/>
                </dxr:BackstageViewControl>
            </dxr:RibbonControl.ApplicationMenu>
            
            <dxr:RibbonControl.PageHeaderItems>
                <dxb:BarButtonItem Name="eDescription"
                                   Glyph="{dx:DXImage SvgImages/Icon Builder/Actions_Info.svg}"
                                   Command="{Binding NavigateToHomeSiteCommand}" />
                <dxb:BarItemLink BarItemName="ribbonStyleItem" RibbonStyle="SmallWithText" />
            </dxr:RibbonControl.PageHeaderItems>
            
            <dxr:RibbonPageCategory x:Name="selectionPageCategory"
                                    Color="PowderBlue"
                                    Caption=""
                                    >
                <dxr:RibbonPage Caption="Views" >
                    <dxr:RibbonPageGroup Caption="Views">
                        <dxb:BarCheckItem Content="Start page"
                                      Command="{DXCommand  Execute='OpenOrCloseWorkspace(@parameter)'}" CommandParameter="{DXBinding 'StartViewModel'}"
                                          Glyph="{dx:DXImage 'SvgImages/Icon Builder/Actions_Home.svg'}"
                                          IsChecked="{DXBinding 'StartViewModel.IsOpened', Mode=OneWay}" />
                        <dxb:BarCheckItem Content="Solution"
                                      Command="{DXCommand  Execute='OpenOrCloseWorkspace(@parameter)'}" CommandParameter="{DXBinding 'SolutionExplorerViewModel'}"
                                          Glyph="{dx:DXImage 'SvgImages/Dashboards/AutoExpand.svg'}"
                                          IsChecked="{DXBinding 'SolutionExplorerViewModel.IsOpened', Mode=OneWay}" />
                    </dxr:RibbonPageGroup>
                </dxr:RibbonPage>
                <dxr:RibbonPage Caption="Help" >
                    <dxr:RibbonPageGroup Caption="Help">
                        <dxb:BarButtonItem Content="Support"
                                          Glyph="{dx:DXImage 'SvgImages/Outlook Inspired/Support.svg'}"
                                           />
                        <dxb:BarButtonItem Content="Update"
                                          Glyph="{dx:DXImage 'SvgImages/RichEdit/UpdateTableOfContents2.svg'}"
                                           />
                    </dxr:RibbonPageGroup>
                </dxr:RibbonPage>
            </dxr:RibbonPageCategory>
        </dxr:RibbonControl>
        
        
        
        <dxdo:DockLayoutManager Grid.Row="1" x:Name="DemoDockContainer" FloatingMode="Desktop" ViewStyle="Light"  ItemsSource="{Binding Workspaces}"
                                    DockingStyle="VS2010" FloatingDocumentContainer="SingleDocument" >
            <dxmvvm:Interaction.Behaviors>
                <p1:DockingSerializationDialogService/>
            </dxmvvm:Interaction.Behaviors>
            <dxdo:LayoutGroup Name="Root">
                <dxdo:LayoutGroup Orientation="Vertical" ItemWidth="3*">
                    <dxdo:LayoutGroup ItemHeight="3*">
                        <dxdo:LayoutGroup Name="Toolbox" DestroyOnClosingChildren="False" ItemWidth="190"/>
                        <dxdo:LayoutGroup ItemWidth="3*" DestroyOnClosingChildren="False">
                            <dxdo:LayoutGroup >
                                <dxdo:DocumentGroup Name="DocumentHost" DestroyOnClosingChildren="False" 
                                                        ClosePageButtonShowMode="InActiveTabPageHeader" Background="Transparent"/>
                            </dxdo:LayoutGroup>
                        </dxdo:LayoutGroup>
                    </dxdo:LayoutGroup>
                    <dxdo:TabbedGroup Name="BottomHost" DestroyOnClosingChildren="False"/>
                </dxdo:LayoutGroup>
                <dxdo:LayoutGroup Name="RightHost" DestroyOnClosingChildren="False" Orientation="Vertical" ItemWidth="290"/>
            </dxdo:LayoutGroup>
        </dxdo:DockLayoutManager>

        <dxb:BarContainerControl ContainerType="Bottom" Grid.Row="2">
            <dxb:StatusBarControl Caption="Status Bar">
                <dxb:BarStaticItem Content="{Binding Status}" Margin="10,0,0,0" Alignment="Far">
                    <dxb:BarStaticItem.ContentTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="15" FontWeight="Bold"/>
                        </DataTemplate>
                    </dxb:BarStaticItem.ContentTemplate>
                </dxb:BarStaticItem>
            </dxb:StatusBarControl>
        </dxb:BarContainerControl>
        
    </Grid>
</UserControl>
