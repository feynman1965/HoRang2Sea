<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HoRang2Sea.Views"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
     xmlns:viewModel="clr-namespace:HoRang2Sea.ViewModels"
    xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxprg="http://schemas.devexpress.com/winfx/2008/xaml/propertygrid" xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid" x:Class="HoRang2Sea.Views.PropertyView"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <dxdo:LayoutGroup Orientation="Vertical">

            <!--
        <Image Source="{Binding PropertyImagePath}" Grid.Column="0" Grid.Row="0" Width="500" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform"  Margin="5,5,5,5" />
!-->
        <dxdo:LayoutPanel ShowCaption="False">
            <Image Source="{Binding PropertyImagePath}"
       Grid.Column="0"
       Grid.Row="0"
       HorizontalAlignment="Center"
       VerticalAlignment="Center"
               Stretch="Uniform"
             MouseWheel="Image_MouseWheel"
       MouseDown="Image_MouseDown"
       MouseMove="Image_MouseMove"
              
       MouseUp="Image_MouseUp">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="scaleTransform"
                            CenterX="0.5"
                            CenterY="0.5" />
                        <TranslateTransform x:Name="translateTransform" />
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>
        </dxdo:LayoutPanel>


        <dxdo:LayoutPanel ShowCaption="False">
            <dxg:GridControl Name="gridControl" Grid.Column="0" Grid.Row="1" AutoGenerateColumns="KeepOld"
                         EnableSmartColumnsGeneration="True" ItemsSource="{Binding Data}" 
                         AutoExpandAllGroups="True">


                <dxg:GridControl.Columns>
                    <dxg:GridColumn Fixed="Left" Header="Show"
                                        FixedWidth="True" Width="20" AllowResizing="False"
                                        ShowInColumnChooser="False" AllowFocus="False"
                                        AllowSorting="False" AllowColumnFiltering="False" AllowGrouping="False"
                                        AllowMoving="False" AllowConditionalFormattingMenu="False" AllowPrinting="False"
                                        AllowSearchPanel="False" AllowBestFit="False" AllowAutoFilter="False" AllowCellMerge="False">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:ButtonEdit ShowText="False" AllowDefaultButton="False" ShowBorder="False">
                                    <dxe:ButtonEdit.Buttons>
                                        <dxe:ButtonInfo GlyphKind="Apply"  Command="{Binding View.DataContext.InputShowHideRefreshCommand}" CommandParameter="{Binding RowData.Row}" />
                                    </dxe:ButtonEdit.Buttons>
                                </dxe:ButtonEdit>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn FieldName="Name" AllowEditing="False"/>
                    <dxg:GridColumn FieldName="Init">
                        <dxg:GridColumn.EditSettings>
                            <dxe:TextEditSettings DisplayFormat="d" MaskType="RegEx" Mask="[0-9.e\-+]*"/>
                        </dxg:GridColumn.EditSettings>

                        <!--
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings DisplayFormat="d" MaskType="RegEx" Mask="[0-9.e\-+]*"/>
                    </dxg:GridColumn.EditSettings> -->
                    </dxg:GridColumn>
                    <dxg:GridColumn FieldName="Unit" AllowEditing="False"/>
                    <dxg:GridColumn FieldName="Min" AllowEditing="False"/>
                    <dxg:GridColumn FieldName="Max" AllowEditing="False"/>
                    <dxg:GridColumn FieldName="Digit" AllowEditing="False"/>
                </dxg:GridControl.Columns>

                <dxg:GridControl.View >
                    <dxg:TableView BestFitMode="AllRows">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand EventName="CellValueChanged"
                                               Command="{Binding CellValueRefreshCommand}"
                                               PassEventArgsToCommand="True">
                                <dxmvvm:EventToCommand.EventArgsConverter>
                                    <dx:EventArgsToDataRowConverter/>
                                </dxmvvm:EventToCommand.EventArgsConverter>
                            </dxmvvm:EventToCommand>
                        </dxmvvm:Interaction.Behaviors>
                    </dxg:TableView>
                </dxg:GridControl.View>
            </dxg:GridControl>

        </dxdo:LayoutPanel>

        <dxdo:LayoutPanel ShowCaption="False">
            <dxg:GridControl Name="gridControl2" Grid.Column="0" Grid.Row="2" AutoGenerateColumns="KeepOld"
                         EnableSmartColumnsGeneration="True" ItemsSource="{Binding OutputData}" 
                         AutoExpandAllGroups="True" Margin="0,10,0,0">


                <dxg:GridControl.Columns>
                    <dxg:GridColumn Fixed="Left" Header="Show"
                                        FixedWidth="True" Width="50" AllowResizing="False"
                                        ShowInColumnChooser="False" AllowFocus="False"
                                        AllowSorting="False" AllowColumnFiltering="False" AllowGrouping="False"
                                        AllowMoving="False" AllowConditionalFormattingMenu="False" AllowPrinting="False"
                                        AllowSearchPanel="False" AllowBestFit="False" AllowAutoFilter="False" AllowCellMerge="False">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <dxe:ButtonEdit ShowText="False" AllowDefaultButton="False" ShowBorder="False">
                                    <dxe:ButtonEdit.Buttons>
                                        <dxe:ButtonInfo GlyphKind="Apply"  Command="{Binding View.DataContext.OutputShowHideRefreshCommand}" CommandParameter="{Binding RowData.Row}" />
                                    </dxe:ButtonEdit.Buttons>
                                </dxe:ButtonEdit>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn FieldName="Name" AllowEditing="False" Width="300"/>
                    <dxg:GridColumn FieldName="Unit" AllowEditing="False"/>
                </dxg:GridControl.Columns>

                <dxg:GridControl.View >
                    <dxg:TableView BestFitMode="AllRows">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand EventName="CellValueChanged"
                                               Command="{Binding CellValueRefreshCommand}"
                                               PassEventArgsToCommand="True">
                                <dxmvvm:EventToCommand.EventArgsConverter>
                                    <dx:EventArgsToDataRowConverter/>
                                </dxmvvm:EventToCommand.EventArgsConverter>
                            </dxmvvm:EventToCommand>
                        </dxmvvm:Interaction.Behaviors>
                    </dxg:TableView>

                </dxg:GridControl.View>
            </dxg:GridControl>
        </dxdo:LayoutPanel>
    </dxdo:LayoutGroup>
</UserControl>
