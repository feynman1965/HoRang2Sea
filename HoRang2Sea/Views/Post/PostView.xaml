<UserControl x:Class="HoRang2Sea.Views.PostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
             xmlns:local="clr-namespace:HoRang2Sea.Views" 
             xmlns:viewmodels="clr-namespace:HoRang2Sea.ViewModels" 
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars" xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid" 
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core" 
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm" 
              xmlns:dxr="http://schemas.devexpress.com/winfx/2008/xaml/ribbon" 
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
             
             xmlns:p1="clr-namespace:HoRang2Sea.Services"
             mc:Ignorable="d" 
             xmlns:s="http://schemas.abtsoftware.co.uk/scichart"
             d:DesignHeight="450" d:DesignWidth="600" Loaded="OnLoaded">
    <UserControl.Resources>
        <DataTemplate x:Key="GridPropertyDialogTemplate">
            <local:GridPropertyView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:PostGridViewModel}">
            <local:PostGridView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:PostChartViewModel}">
            <local:PostChartView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:PostTimeChartViewModel}">
            <local:PostTimeChartView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewmodels:PostGaugeViewModel}">
            <local:PostGaugeView/>
        </DataTemplate>

        <viewmodels:BoolToValueConverter x:Key="BoolToVisibilityConverter"
                                      FalseValue="Collapsed"
                                      TrueValue="Visible" />


    </UserControl.Resources>

    <dxmvvm:Interaction.Behaviors>
        <dx:DialogService x:Name="GridPropertyDialogService" ViewTemplate="{StaticResource GridPropertyDialogTemplate}">
            <dx:DialogService.DialogStyle>
                <Style TargetType="Window">
                    <Setter Property="Width" Value="600" />
                    <Setter Property="MaxWidth" Value="1000" />
                    <Setter Property="WindowStyle" Value="ToolWindow" />
                </Style>
            </dx:DialogService.DialogStyle>
        </dx:DialogService>

   

    </dxmvvm:Interaction.Behaviors>

    <dxb:BarManager>
        <dxb:BarManager.Items>
            <dxb:BarButtonItem Name="bGridProperties" Content="Grid Properties" CategoryName="Solution" Glyph="{dx:DXImage 'SvgImages/RichEdit/TableProperties.svg'}" Hint="Grid Property" Command="{Binding OnGridPropertyCommand}" />
            <dxb:BarButtonItem Name="bAddTimeChart" Content="Add TimeChart" CategoryName="Solution" Glyph="{dx:DXImage 'SvgImages/Chart/ChartType_SwiftPlot.svg'}" Hint="Add Time Chart" Command="{Binding OnAddTimeChartCommand}" />
            <dxb:BarButtonItem Name="bAddXYChart" Content="Add XYChart" CategoryName="Solution" Glyph="{dx:DXImage 'SvgImages/Chart/ChartType_Line.svg'}" Hint="Add XYChart" Command="{Binding OnAddChartCommand}" />
            <dxb:BarButtonItem Name="bAddGauge" Content="Add Gauge" CategoryName="Solution" Glyph="{dx:DXImage 'SvgImages/Dashboards/GaugeStyleThreeFourthCircular.svg'}" Hint="Add Gauge" Command="{Binding OnAddGaugeCommand}"/>
            <dxb:BarButtonItem Name="bReport" Content="Report" CategoryName="Solution" Glyph="{dx:DXImage 'SvgImages/DiagramIcons/save as.svg'}" Hint="Save Post" Command="{Binding OnReportCommand}"/>
            
            
            <dxb:BarButtonItem Name="bPlay"
                                       Content="Play"
                                       Glyph="{iconPacks:IoniconsImage Kind=PlayiOS,Brush=DarkBlue}" 
                                       Hint=""
                                       RibbonStyle="SmallWithText" />
            <dxb:BarButtonItem Name="bPause"
                                       Content="Pause"
                                       Glyph="{iconPacks:IoniconsImage Kind=PauseiOS,Brush=DarkSlateBlue}" GlyphSize="Custom" CustomGlyphSize="13,13"
                                       RibbonStyle="SmallWithText" />
            <dxb:BarButtonItem Name="bForward"
                                       Content="Forward"
                                       Glyph="{iconPacks:IoniconsImage Kind=SkipForwardiOS,Brush=DarkBlue}" GlyphSize="Custom" CustomGlyphSize="13,13"
                                       Hint=""
                                       RibbonStyle="SmallWithText" />
            <dxb:BarButtonItem Name="bStop"
                                       Content="Stop"
                                       Glyph="{iconPacks:IoniconsImage Kind=SquareOutlineMD,Brush=Crimson}" GlyphSize="Custom" CustomGlyphSize="14,14"
                                       RibbonStyle="SmallWithText" />
            <dxb:BarButtonItem Name="bRedo"
                                       Content="Redo"
                                       Glyph="{iconPacks:IoniconsImage Kind=RefreshMD ,Brush=DodgerBlue, Flip=Horizontal}" GlyphSize="Custom" CustomGlyphSize="14,14"
                                       Hint="Redo"
                                       RibbonStyle="SmallWithText" />
        </dxb:BarManager.Items>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <dxr:RibbonControl 
            x:Name="RibbonControl" 
                           ShowApplicationButton ="False"
                           PageCategoryAlignment="Default"
                           RibbonTitleBarVisibility="Visible"
                           RibbonStyle="Office2019"
                           ToolbarShowMode="Default"
                           IsSimplified="True"
                           >
                <dxr:RibbonPage Caption="Post">
                    <dxr:RibbonPageGroup Caption="Player" ShowCaptionButton="False" SmallGlyph="{iconPacks:FontistoImage Kind=Equalizer}">
                        <dxb:BarButtonItemLink BarItemName="bGridProperties" />
                        <dxb:BarButtonItemLink BarItemName="bAddTimeChart"/>
                        <dxb:BarButtonItemLink BarItemName="bAddXYChart"/>
                        <dxb:BarButtonItemLink BarItemName="bAddGauge"/>
                        <dxb:BarButtonItemLink BarItemName="bReport"/>
                        
                    </dxr:RibbonPageGroup>
                </dxr:RibbonPage>
                <dxr:RibbonPageCategory x:Name="selectionPageCategory"
                                    Caption="Image tools"
                                    IsVisible="False">
                    <dxr:RibbonPage x:Name="pSelection" Caption="Format">
                        <dxr:RibbonPageGroup Caption="Clipboard">
                        </dxr:RibbonPageGroup>
                    </dxr:RibbonPage>
                </dxr:RibbonPageCategory>
            </dxr:RibbonControl>
            <dxb:BarContainerControl x:Name="SolutionBar" Width="100" Grid.Row="0" HorizontalAlignment="Left" Margin="0,5,0,0"/>
            
            <dxdo:DockLayoutManager x:Name="DemoDockContainer" FloatingMode="Desktop" ViewStyle="Light"  ItemsSource="{Binding PostWorkspaces}"
                                    DockingStyle="VS2010"  FloatingDocumentContainer="SingleDocument" Grid.Row="1">
                
                
                <dxdo:LayoutGroup Orientation="Vertical" Name ="PostViewRoot">

                    <dxdo:LayoutGroup Orientation="Vertical" ItemWidth="3*">
                        <dxdo:LayoutGroup ItemHeight="*">
                            <dxdo:LayoutGroup Name="Toolbox" DestroyOnClosingChildren="False" ItemWidth="190"/>

                            <dxdo:LayoutGroup ItemWidth="3*" DestroyOnClosingChildren="False">
                                <dxdo:LayoutGroup ItemHeight="*" >
                                    <dxdo:LayoutGroup Name="TopHost" DestroyOnClosingChildren="False" 
                                                        Margin="0,5,0,0" />
                                </dxdo:LayoutGroup>
                            </dxdo:LayoutGroup>
                        </dxdo:LayoutGroup>

                        <dxdo:LayoutGroup Name="BottomHost" DestroyOnClosingChildren="False"  Margin="0,10,0,0"/>
                    </dxdo:LayoutGroup>

                </dxdo:LayoutGroup>
            </dxdo:DockLayoutManager>
        </Grid>
    </dxb:BarManager>
</UserControl>



