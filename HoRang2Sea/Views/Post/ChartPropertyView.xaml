<UserControl x:Class="HoRang2Sea.Views.ChartPropertyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HoRang2Sea.Views" 
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <!-- Row 0: Labels -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Search Box -->
            <RowDefinition Height="*"/>
            <!-- Row 2: ListBoxes -->
            <RowDefinition Height="30"/>
            <!-- Row 3: Y Axis Label -->
            <RowDefinition Height="*"/>
            <!-- Row 4: Y Axis ListBox -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Column 0 -->
            <ColumnDefinition Width="*"/>
            <!-- Column 1 -->
        </Grid.ColumnDefinitions>

        <!-- Labels -->
        <Label Grid.Column="0" Grid.Row="0"
               Content="Global Items" Foreground="Gray" FontSize="14"/>
        <Label Grid.Column="1" Grid.Row="0"
               Content="X Axis Item" Foreground="Gray" FontSize="14"/>

        <!-- Search Box under Global Items -->
        <dxe:TextEdit Grid.Column="0" Grid.Row="1" Margin="5"
                      Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" 
                      NullText="Search..."/>

        <!-- ListBoxes -->
        <dxe:ListBoxEdit ItemsSource="{Binding FilteredChartGlobalItems}" Grid.Column="0" Grid.Row="2" Margin="5"
                         dx:ListBoxDragDropBehavior.AllowDragDrop="True"
                         dx:ListBoxDragDropBehavior.DragRecordOver="OnDragRecordOver" />

        <dxe:ListBoxEdit ItemsSource="{Binding ChartXItems}" Grid.Column="1" Grid.Row="2" Margin="5"
                         dx:ListBoxDragDropBehavior.AllowDragDrop="True"
                         dx:ListBoxDragDropBehavior.DragRecordOver="OnXDragRecordOver" />

        <!-- Y Axis Label -->
        <Label Grid.Column="1" Grid.Row="3"
               Content="Y Axis Item" Foreground="Gray" FontSize="14"/>

        <!-- Y Axis ListBox -->
        <dxe:ListBoxEdit ItemsSource="{Binding ChartYItems}" Grid.Column="1" Grid.Row="4" Margin="5"
                         dx:ListBoxDragDropBehavior.AllowDragDrop="True"
                         dx:ListBoxDragDropBehavior.DragRecordOver="OnYDragRecordOver" />
    </Grid>
</UserControl>
