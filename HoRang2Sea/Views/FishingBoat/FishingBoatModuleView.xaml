<UserControl x:Class="HoRang2Sea.Views.FishingBoatModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HoRang2Sea.Views"
             xmlns:viewModel="clr-namespace:HoRang2Sea.Models"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
              xmlns:dxdiag="http://schemas.devexpress.com/winfx/2008/xaml/diagram" 
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxr="http://schemas.devexpress.com/winfx/2008/xaml/ribbon" 
    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars" 
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{Binding LayoutBackgroundColor}"
             BorderBrush="{Binding LayoutAccentColor}"
             BorderThickness="3">

    <UserControl.Resources>
        <Style x:Key="tableStyle" TargetType="{x:Type dxdiag:DiagramList}">
            <Setter Property="AffectedByLayoutAlgorithms" Value="False" />
            <Setter Property="CanChangeParent" Value="False" />
            <Setter Property="CanCopy" Value="False" />
            <Setter Property="CanEdit" Value="False" />
            <Setter Property="CanResize" Value="True" />
            <Setter Property="CanCollapse" Value="True"/>
            <Setter Property="DragMode" Value="ByAnyPoint" />
            <Setter Property="ConnectionPoints" Value="0,0.5 1,0.5" />
            <Setter Property="Header" Value="{Binding Name}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="ShowHeader" Value="True" />
            <Setter Property="Padding" Value="3,2" />
            <Setter Property="Width" Value="350"/>
            <Setter Property="FontSize" Value="35"/>
            <Setter Property="FontStyle"  Value="Normal" />
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Background" Value="AliceBlue"/>
            <Setter Property="ItemsCanMove" Value="False"/>
            <Setter Property="CanMove" Value="False"/>
            <Setter Property="Position">
                <Setter.Value>
                    <MultiBinding Converter="{viewModel:PositionXYToPointConverter}">
                        <Binding Path="PositionX" />
                        <Binding Path="PositionY" />
                    </MultiBinding>
                </Setter.Value>
            </Setter>
            <Setter Property="StrokeThickness" Value="2" />
        </Style>

        <Style x:Key="columnStyle" TargetType="{x:Type dxdiag:DiagramContentItem}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CanSnapToThisItem" Value="False" />
            <Setter Property="CanChangeParent" Value="False"/>
            <Setter Property="ConnectionPoints" Value="0,0.5 1,0.5" />
            <Setter Property="Content" Value="{Binding}" />
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <dx:DXImage Name="image" Source="{dx:DXImage 'SvgImages/PDF Viewer/SearchSettingButton.svg'}" Margin="0" Height="20" Width="20" />
                            <TextBlock Grid.Column="1" Text="{Binding Name}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5"  FontSize="20" />
                            <dxe:TextEdit Grid.Column="2" Text="{Binding Init}" HorizontalAlignment="Right" Width="150"  
                                          Margin="10,0" FontSize="20" MaskType="RegEx" Mask="[0-9.e\-+]*">
                            </dxe:TextEdit>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsPrimaryKey}" Value="True">
                                <Setter TargetName="image" Property="Source" Value="/HoRang2Sea;component/Resource/id.svg" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="TextAlignment" Value="Left" />
        </Style>

        <Style x:Key="ImageStyle" TargetType="{x:Type dxdiag:DiagramContentItem}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CanSnapToThisItem" Value="False" />
            <Setter Property="ConnectionPoints" Value="0,0.5 1,0.5" />
            <Setter Property="CanChangeParent" Value="False"/>
            <Setter Property="Content" Value="{Binding}" />
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Grid Height="200" Width="350">
                            <dx:DXImage Name="image" Source="{Binding ImagePath}" Margin="4,2" Height="130" Width="180" Stretch="Uniform" />
                        </Grid>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="TextAlignment" Value="Left" />
        </Style>


        <Style x:Key="outputStyle" TargetType="{x:Type dxdiag:DiagramContentItem}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CanSnapToThisItem" Value="False" />
            <Setter Property="CanChangeParent" Value="False"/>
            <Setter Property="ConnectionPoints" Value="0,0.5 1,0.5" />
            <Setter Property="Content" Value="{Binding}" />
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <dx:DXImage Name="image" Source="{dx:DXImage 'SvgImages/Chart/ChartType_Bar.svg'}" Margin="0" Height="20" Width="20" />
                            <TextBlock Grid.Column="1" Text="{Binding Name}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5"  FontSize="20" />
                            <dxe:TextEdit Grid.Column="2" Text="{Binding Value}" HorizontalAlignment="Right" Width="150"  Margin="10,0" FontSize="20" HorizontalContentAlignment="Right"/>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsPrimaryKey}" Value="True">
                                <Setter TargetName="image" Property="Source" Value="/HoRang2Sea;component/Resource/id.svg" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="TextAlignment" Value="Left" />
        </Style>



        <viewModel:DatabaseDefinitionKeySelector x:Key="databaseDefinitionKeySelector" />

        <DataTemplate x:Key="PropertyTemplate">
            <local:PropertyView/>
        </DataTemplate>

        <!-- Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>

    <DockPanel>
        <dxr:RibbonControl 
            x:Name="RibbonControl" DockPanel.Dock="Top"
                           ShowApplicationButton ="False"
                           PageCategoryAlignment="Default"
                           RibbonTitleBarVisibility="Visible"
                           RibbonStyle="Office2019"
                           ToolbarShowMode="Default"
                           IsSimplified="True"
                           >
            <dxr:RibbonControl.ToolbarItems>
                <dxr:RibbonSpacingSelectorItemLink BarItemName="spacingSelector" />
                <dxb:BarItemLink BarItemName="bPlay" VerticalAlignment="Center"/>
                <dxb:BarItemLink BarItemName="bPause" VerticalAlignment="Center"/>
                <dxb:BarItemLink BarItemName="bNextStep" VerticalAlignment="Center"/>
                <dxb:BarItemLink BarItemName="bStop" VerticalAlignment="Center"/>
                <dxb:BarItemLink BarItemName="bRedo" VerticalAlignment="Center"/>
                <dxb:BarItemLink BarItemName="bSetStep" VerticalAlignment="Center"/>
                <dxb:BarItemLink BarItemName="bSave" VerticalAlignment="Center"/>
            </dxr:RibbonControl.ToolbarItems>
            <dxr:RibbonPage Caption="Monitor">
                <dxr:RibbonPageGroup Caption="File Operations" ShowCaptionButton="False">
                    <dxb:BarButtonItem Name="bLoadFile"
                                       Content="Load Slip Txt"
                                       Glyph="{iconPacks:IoniconsImage Kind=DocumentiOS,Brush=DarkBlue}"
                                       Command="{Binding UploadVelocityCommand}" 
                                       Hint=""
                                       RibbonStyle="SmallWithText" />
                    <dxb:BarButtonItem Name="bRemoveText"     
                                       Content="Remove Txt (to default)"
                                       Glyph="{iconPacks:IoniconsImage Kind=DocumentiOS,Brush=SkyBlue}"
                                       Command="{Binding RemoveTextCommand}"
                                       RibbonStyle="SmallWithText" />
                    
                </dxr:RibbonPageGroup>                   

                <dxr:RibbonPageGroup Caption="Player" ShowCaptionButton="False" SmallGlyph="{iconPacks:FontistoImage Kind=Equalizer}">
                    <dxb:BarButtonItem Name="bPlay"
                                       Content="Run"
                                       Glyph="{iconPacks:IoniconsImage Kind=PlayiOS,Brush=DarkBlue}" 
                                       Command="{Binding OnClickCalculateButtonCommand}"
                                       Hint=""
                                       RibbonStyle="SmallWithText" />
                    <dxb:BarButtonItem Name="bPause"
                                       Content="Pause"
                                       Command="{Binding OnClickPauseButtonCommand}"
                                       Glyph="{iconPacks:IoniconsImage Kind=PauseiOS,Brush=DarkSlateBlue}" GlyphSize="Custom" CustomGlyphSize="13,13"
                                       RibbonStyle="SmallWithText" />
                    <dxb:BarButtonItem Name="bNextStep"
                                       Content="Step Forward"
                                       Command="{Binding OnClickNextStepButtonCommand}"
                                       Glyph="{iconPacks:IoniconsImage Kind=SkipForwardiOS,Brush=DarkBlue}" GlyphSize="Custom" CustomGlyphSize="13,13"
                                       Hint=""
                                       RibbonStyle="SmallWithText" />
                    <dxb:BarButtonItem Name="bStop"
                                       Content="Stop"
                                       Command="{Binding OnClickStopButtonCommand}"
                                       Glyph="{iconPacks:IoniconsImage Kind=SquareOutlineMD,Brush=Crimson}" GlyphSize="Custom" CustomGlyphSize="14,14"
                                       RibbonStyle="SmallWithText" />
                    
                    <!--
                    <dxb:BarButtonItem Name="bSetStep"
                                       Content="SetStep"
                                       Glyph="{dx:DXImage 'SvgImages/Dashboards/YAxisSettings.svg'}"
                                       Hint="Step"
                                       RibbonStyle="SmallWithText" />

                    
                    <dxb:BarButtonItem Name="bSave"
                                       Content="Save"
                                       Glyph="{iconPacks:IoniconsImage Kind=PlayiOS,Brush=DarkBlue}" 
                                       Command="{Binding OnClickSaveButtonCommand}"
                                       Hint=""
                                       RibbonStyle="SmallWithText" />
                    !-->

                </dxr:RibbonPageGroup>

                <dxr:RibbonPageGroup Caption="Layout" ShowCaptionButton="False">
                    <dxb:BarButtonItem Name="btnSelectLayout"
                                       Content="Select Layout"
                                       Glyph="{dx:DXImage 'SvgImages/Dashboards/SwitchViewType.svg'}"
                                       Command="{Binding SelectLayoutCommand}"
                                       RibbonStyle="SmallWithText" />
                    <dxb:BarStaticItem Name="currentLayout"
                                       Content="{Binding CurrentLayoutName, StringFormat='Current: {0}'}"
                                       Foreground="{Binding LayoutAccentColor}"
                                       RibbonStyle="SmallWithText" />
                </dxr:RibbonPageGroup>

                <dxr:RibbonPageGroup Caption="Panels" ShowCaptionButton="False">
                    <dxb:BarCheckItem Name="chkVelocityProfile"
                       Content="Velocity Profile"
                       Glyph="{dx:DXImage 'SvgImages/Chart/LineChart.svg'}"
                       IsChecked="{Binding IsVelocityProfileVisible, Mode=TwoWay}"
                       RibbonStyle="SmallWithText" />
                    <dxb:BarCheckItem Name="chkGridProperties"
                       Content="Grid Properties"
                       Glyph="{dx:DXImage 'SvgImages/Spreadsheet/ShowDetail.svg'}"
                       IsChecked="{Binding IsGridVisible, Mode=TwoWay}"
                       RibbonStyle="SmallWithText" />
                    <dxb:BarCheckItem Name="chkTimeChart"
                       Content="Time Chart"
                       Glyph="{dx:DXImage 'SvgImages/Chart/ChartType_Line.svg'}"
                       IsChecked="{Binding IsTimeChartVisible, Mode=TwoWay}"
                       RibbonStyle="SmallWithText" />
                    <dxb:BarCheckItem Name="chkXYChart"
                       Content="XY Chart"
                       Glyph="{dx:DXImage 'SvgImages/Chart/ChartType_Point.svg'}"
                       IsChecked="{Binding IsXYChartVisible, Mode=TwoWay}"
                       RibbonStyle="SmallWithText" />
                </dxr:RibbonPageGroup>
            </dxr:RibbonPage>
            <dxr:RibbonPageCategory x:Name="selectionPageCategory"
                                    Caption="Image tools"
                                    IsVisible="False">
                <dxr:RibbonPage x:Name="pSelection" Caption="Format">
                    <dxr:RibbonPageGroup Caption="Clipboard">
                    </dxr:RibbonPageGroup>
                </dxr:RibbonPage>
            </dxr:RibbonPageCategory>
        </dxr:RibbonControl>
        <dxdo:DockLayoutManager FloatingMode="Desktop" ShowFloatWindowsInTaskbar="False" CloseFloatWindowsOnManagerUnloading="True">
            <dxdo:LayoutGroup Margin="0" Orientation="Horizontal">
                <!-- 왼쪽: Diagram + Velocity Profile -->
                <dxdo:LayoutGroup Orientation="Vertical" ItemWidth="*">
                    <dxdo:DocumentPanel x:Name="diagramPanel">
                        <dxdiag:DiagramControl Name="diagramControl"
                           LineJumpPlacement="HorizontalLines"
                           AllowCollapseContainers="True"
                           IsReadOnly="True"
                           CanvasSizeMode="Fill"
                           ShowGrid="True"
                           ShowRulers="False"
                           ScrollMode="Page"
                           ShowPageBreaks="False"
                           FitToDrawingMargin="50"
                           PointerToolDragMode="Pan"
                           ShowPanAndZoomPanel="True"  
                           AllowMoveItems="True"
                  
                           SelectionMode="Single"
                            >

                            <dxmvvm:Interaction.Behaviors>
                                <dxdiag:DiagramDataBindingBehavior ItemsSource="{Binding Database.Tables}"
                                                           ItemsPath="VisibleData"
                                               ConnectorsSource="{Binding Database.Connections}"
                                               KeySelector="{StaticResource databaseDefinitionKeySelector}"
                                               ConnectorFromMember="From"
                                               ConnectorToMember="To"

                                               >
                                    <dxdiag:DiagramDataBindingBehavior.ConnectorTemplate>
                                        <DataTemplate>
                                            <dxdiag:DiagramConnector StrokeThickness="10"
                                                 FontSize="15"
                                                 ContentBackground="Black"
                                                 BeginLabelConnectorOffset="20"
                                                 BeginLabelArrowOffset="20"
                                                 EndLabelConnectorOffset="20"
                                                 EndLabelArrowOffset="20"
                                                 CanDragBeginPoint="False"
                                                 CanChangeRoute="False"
                                                 CanDragEndPoint="False"
                                                 CanEdit="False"
                                                 Stroke="DarkSlateBlue"
                                                 BeginArrowSize="5,5"
                                                 EndArrowSize="6,6"
                                                 Type="RightAngle">
                                                <!--
                                        <dxdiag:DiagramConnector.Bindings>
                                            <dxdiag:DiagramBinding PropertyName="BeginLeftLabel" Expression="TableRelation([DataItem.FromRelation])" />
                                            <dxdiag:DiagramBinding PropertyName="EndLeftLabel" Expression="TableRelation([DataItem.ToRelation])" />
                                        </dxdiag:DiagramConnector.Bindings>
                    
                                        !-->
                                            </dxdiag:DiagramConnector>
                                        </DataTemplate>
                                    </dxdiag:DiagramDataBindingBehavior.ConnectorTemplate>

                                    <dxdiag:DiagramDataBindingBehavior.ItemTemplateSelector>
                                        <viewModel:DatabaseDiagramItemTemplateSelector>
                                            <viewModel:DatabaseDiagramItemTemplateSelector.TableTemplate>
                                                <DataTemplate DataType="{x:Type viewModel:TableDefinition}">
                                                    <dxdiag:DiagramList CustomStyleId="tableStyle" Shape="StandardContainers.Alternating" >

                                                        <!-- <dxmvvm:Interaction.Behaviors>
                                                    <model:DiagramItemClickBehavior EditCommand="{Binding Path=AssociatedObject.(dxdiag:DiagramControl.Diagram).DataContext.EditCommand, RelativeSource={RelativeSource Mode=Self}}"/>
                                                </dxmvvm:Interaction.Behaviors>-->

                                                    </dxdiag:DiagramList>
                                                </DataTemplate>
                                            </viewModel:DatabaseDiagramItemTemplateSelector.TableTemplate>

                                            <viewModel:DatabaseDiagramItemTemplateSelector.ColumnTemplate>
                                                <DataTemplate DataType="{x:Type viewModel:ColumnDefinition}">
                                                    <dxdiag:DiagramContentItem CustomStyleId="columnStyle"/>
                                                </DataTemplate>
                                            </viewModel:DatabaseDiagramItemTemplateSelector.ColumnTemplate>

                                            <viewModel:DatabaseDiagramItemTemplateSelector.ImageTemplate>
                                                <DataTemplate DataType="{x:Type viewModel:ImageDefinition}">
                                                    <dxdiag:DiagramContentItem CustomStyleId="ImageStyle" />
                                                </DataTemplate>
                                            </viewModel:DatabaseDiagramItemTemplateSelector.ImageTemplate>

                                            <viewModel:DatabaseDiagramItemTemplateSelector.OutputTemplate>
                                                <DataTemplate DataType="{x:Type viewModel:OutputDefinition}">
                                                    <dxdiag:DiagramContentItem CustomStyleId="outputStyle" />
                                                </DataTemplate>
                                            </viewModel:DatabaseDiagramItemTemplateSelector.OutputTemplate>


                                        </viewModel:DatabaseDiagramItemTemplateSelector>
                                    </dxdiag:DiagramDataBindingBehavior.ItemTemplateSelector>
                                </dxdiag:DiagramDataBindingBehavior>

                                <dxmvvm:EventToCommand SourceName="diagramControl" EventName="MouseDoubleClick" Command="{Binding DiagramDoubleClickedCommand}" 
                                               CommandParameter="{Binding ElementName=diagramControl, Path=SelectedItems}">
                                </dxmvvm:EventToCommand>

                            </dxmvvm:Interaction.Behaviors>
                        </dxdiag:DiagramControl>
                    </dxdo:DocumentPanel>
                    <dxdo:DocumentPanel x:Name="velocityProfilePanel"
                        Caption="Velocity Profile"
                        Loaded="VelocityProfilePanel_Loaded"
                        Visibility="{Binding IsVelocityProfileVisible, Converter={StaticResource BoolToVisConverter}}">
                        <!-- Content will be added via code-behind -->
                    </dxdo:DocumentPanel>
                </dxdo:LayoutGroup>

                <!-- 중간: Property -->
                <dxdo:LayoutGroup Orientation="Vertical" ItemWidth="*">
                    <dxdo:LayoutPanel Caption="Property"
                        AllowClose="False"
                        AllowDrag="True"
                        AllowFloat="False">
                        <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource PropertyTemplate}" />
                    </dxdo:LayoutPanel>
                </dxdo:LayoutGroup>

                <!-- 오른쪽: 그래프 공간 -->
                <dxdo:LayoutGroup Orientation="Vertical" ItemWidth="*" Background="White">
                    <dxdo:DocumentPanel x:Name="gridPanel"
                        Caption="Grid Properties"
                        Visibility="{Binding IsGridVisible, Converter={StaticResource BoolToVisConverter}}">
                        <local:PostGridView DataContext="{Binding GridViewModel}"/>
                    </dxdo:DocumentPanel>

                    <dxdo:DocumentPanel x:Name="timeChartPanel"
                        Caption="Time Chart"
                        Visibility="{Binding IsTimeChartVisible, Converter={StaticResource BoolToVisConverter}}">
                        <local:PostTimeChartView DataContext="{Binding ChartViewModel}"/>
                    </dxdo:DocumentPanel>

                    <dxdo:DocumentPanel x:Name="xyChartPanel"
                        Caption="XY Chart"
                        Visibility="{Binding IsXYChartVisible, Converter={StaticResource BoolToVisConverter}}">
                        <local:PostChartView DataContext="{Binding XYChartViewModel}"/>
                    </dxdo:DocumentPanel>
                </dxdo:LayoutGroup>
            </dxdo:LayoutGroup>
        </dxdo:DockLayoutManager>
    </DockPanel>
</UserControl>