<dx:ThemedWindow 
    x:Class="HoRang2Sea.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:Views="clr-namespace:HoRang2Sea.Views"
    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
    dx:ThemeManager.ThemeName="Win11Light"
    Title="HoRang2Sea" Height="800" Width="1000"
    Icon="{dx:SvgImageSource Uri='/Resource/tigerh2icon.svg'}"
    ShowIcon="False"
    TitleAlignment="Center">
    <dx:ThemedWindow.ToolbarItems>
        <dxb:MainMenuControl VerticalAlignment="Center"/>
    </dx:ThemedWindow.ToolbarItems>
    <Grid>
        <Views:MainView/>
    </Grid>
</dx:ThemedWindow>
